{
  "name": "riviera",
  "displayName": "Riviera theme",
  "description": "A two-tone pastel color theme with azure and sand accents on a dark background.",
  "version": "0.0.3",
  "publisher": "laander",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Riviera theme",
        "path": "./themes/riviera-color-theme.json",
        "uiTheme": "vs-dark"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/laander/riviera-theme"
  },
  "keywords": [
    "theme",
    "color-theme",
    "dark",
    "pastel"
  ],
  "scripts": {
    "package": "source ~/.nvm/nvm.sh && nvm use 22 && vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.1"
  }
}
